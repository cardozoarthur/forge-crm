  "artifact_types": [
    {
      "id": "crm_system_blueprint",
      "title": "CRM system blueprint",
      "generic_kind": "document"
    },
    {
      "id": "crm_core_gap_report",
      "title": "Forge Core gap report",
      "generic_kind": "report"
    },
    {
      "id": "crm_workflow_pack",
      "title": "CRM workflow pack",
      "generic_kind": "artifact"
    },
    {
      "id": "crm_operating_model",
      "title": "CRM Forge operating model",
      "generic_kind": "artifact"
    },
    {
      "id": "crm_operating_snapshot",
      "title": "CRM operating snapshot",
      "generic_kind": "report"
    },
